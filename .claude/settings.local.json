{
  "permissions": {
    "allow": [
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(cd backend && ./gradlew test*)",
      "Bash(cd backend && ./gradlew build*)",
      "Bash(cd backend && ./gradlew compileJava*)",
      "Bash(grep -rn * backend/src/)",
      "Bash(find backend/src/ *)",
      "Bash(chmod +x *)",
      "Bash(Get-ChildItem -Recurse -Path \"C:\\\\root_project\" -Force)",
      "Bash(Select-Object FullName)",
      "Bash(Sort-Object FullName)",
      "Bash(docker --version)",
      "Bash(docker compose *)",
      "Bash(git *)",
      "Bash(grep -h \"^description:\" .claude/agents/*.md)",
      "Bash(grep:*)",
      "Skill(claude-api)",
      "Skill(claude-api:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git branch -D*)",
      "Bash(git checkout -- *)",
      "Bash(git restore .)",
      "Bash(git restore --staged .)",
      "Bash(rm -rf *)",
      "Bash(rm -f *)",
      "Bash(docker-compose down -v*)",
      "Bash(docker compose down -v*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-tool-check.sh"
          }
        ]
      }
    ]
  }
}
