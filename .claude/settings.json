{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/scripts/pre-commit-test.sh",
            "timeout": 300,
            "statusMessage": "커밋 전 테스트 실행 중..."
          }
        ]
      }
    ]
  }
}
